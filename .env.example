# .env.local

# PostgreSQL 연결 (Supabase, Neon, 로컬 등)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# JWT 시크릿 (openssl rand -base64 64 로 생성 권장)
JWT_ACCESS_SECRET="your-access-secret-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars"

# 토스 페이먼츠
TOSS_SECRET_KEY="test_sk_xxxxxxxxxxxxxx"         # 시크릿 키 (서버 전용)
TOSS_CLIENT_KEY="test_ck_xxxxxxxxxxxxxx"         # 클라이언트 키 (프론트 노출 가능)
NEXT_PUBLIC_TOSS_CLIENT_KEY="test_ck_xxxxxxxxxxxxxx"

# 앱 URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
