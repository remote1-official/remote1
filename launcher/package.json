{
  "name": "remote1-launcher",
  "version": "1.0.0",
  "description": "REMOTE1 Gaming PC Launcher",
  "repository": "https://github.com/remote1-official/remote1",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64 --publish never"
  },
  "build": {
    "appId": "app.remote1.launcher",
    "productName": "REMOTE1",
    "directories": { "output": "dist" },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "uninstallDisplayName": "REMOTE1",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*"
    ],
    "extraResources": [
      { "from": "resources", "to": "resources", "filter": ["**/*"] }
    ]
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  }
}
