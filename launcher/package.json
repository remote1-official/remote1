{
  "name": "remote1-launcher",
  "version": "1.0.0",
  "description": "REMOTE1 게이밍 PC 런처",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "app.remote1.launcher",
    "productName": "REMOTE1",
    "directories": { "output": "dist" },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "electron/**/*",
      "renderer/**/*"
    ],
    "extraResources": [
      { "from": "resources", "to": "resources", "filter": ["**/*"] }
    ]
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  }
}
