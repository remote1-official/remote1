generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id(map: "User_pkey") @default(dbgenerated("(gen_random_uuid())::text"))
  email        String    @unique(map: "User_email_key")
  password     String
  phone        String?
  credits      Int?      @default(30)
  refreshToken String?
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
  updatedAt    DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  username     String?   @unique
  mainGame     String?
  isSuspended  Boolean   @default(false)
  payments     Payment[]
  queues       Queue[]
  sessions     Session[]

  @@map("users")
}

model Payment {
  id           String    @id(map: "Payment_pkey") @default(dbgenerated("(gen_random_uuid())::text"))
  orderId      String    @unique(map: "Payment_orderId_key")
  paymentKey   String?
  amount       Int
  creditsAdded Int
  status       String?   @default("PENDING")
  method       String?
  userId       String?
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
  updatedAt    DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  user         User?     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("payments")
}

model Store {
  id        String    @id @default(cuid())
  name      String
  ipRanges  String?
  gateway1  String?
  gateway2  String?
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  machines  Machine[]

  @@map("stores")
}

model Machine {
  id             String        @id @default(cuid())
  name           String
  sunshineHost   String        @unique
  spec           String?
  isAvailable    Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  currentApp     String?
  currentAppIcon String?
  lastPing       DateTime?
  lastUserId     String?
  localIp        String?
  macAddress     String?
  status         MachineStatus @default(OFF)
  storeId        String?
  pendingPin     String?
  store          Store?        @relation(fields: [storeId], references: [id])
  sessions       Session[]

  @@map("machines")
}

model Queue {
  id        String      @id @default(cuid())
  userId    String
  position  Int
  status    QueueStatus @default(WAITING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @default(now()) @updatedAt
  user      User        @relation(fields: [userId], references: [id])

  @@map("queue")
}

model Session {
  id             String        @id @default(cuid())
  userId         String
  machineId      String
  startedAt      DateTime      @default(now())
  endedAt        DateTime?
  creditsUsed    Int?
  scheduledEndAt DateTime?
  status         SessionStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now()) @updatedAt
  machine        Machine       @relation(fields: [machineId], references: [id])
  user           User          @relation(fields: [userId], references: [id])

  @@map("sessions")
}

enum PaymentStatus {
  PENDING
  DONE
  FAILED
  CANCELED
}

enum MachineStatus {
  OFF
  BOOTING
  READY
  IN_USE
  MAINTENANCE
}

enum QueueStatus {
  WAITING
  ASSIGNED
  CANCELLED
  EXPIRED
}

enum SessionStatus {
  ACTIVE
  ENDED
  INTERRUPTED
}

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  target    String
  detail    String
  createdAt DateTime @default(now())

  @@map("admin_logs")
}
