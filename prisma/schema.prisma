// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String?  @unique
  phone        String?
  password     String
  credits      Int      @default(0)   // 충전된 시간(분) 또는 크레딧
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  payments Payment[]
  sessions Session[]
  queues   Queue[]

  @@map("users")
}

model Payment {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  orderId       String        @unique  // 토스 주문 ID
  paymentKey    String?       // 토스 결제 키 (승인 후)
  amount        Int           // 결제 금액 (원)
  creditsAdded  Int           // 충전된 크레딧
  status        PaymentStatus @default(PENDING)
  method        String?       // 카드, 가상계좌 등
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  DONE
  FAILED
  CANCELED
}

// ─── Remote PC ───────────────────────────────────────────────────────────────

model Machine {
  id            String        @id @default(cuid())
  name          String                              // 표시 이름 (예: PC-1)
  sunshineHost  String        @unique               // Sunshine 서버 IP/호스트 (Moonlight 접속 주소)
  localIp       String?                             // 내부 IP (핑/셧다운용)
  macAddress    String?                             // MAC 주소 (WOL용)
  spec          String?                             // 스펙 정보 (예: i9-13900K / RTX 4090)
  status        MachineStatus @default(OFF)         // 현재 상태
  isAvailable   Boolean       @default(true)        // 관리자가 사용 가능하게 설정했는지
  lastPing      DateTime?                           // 마지막 핑 응답 시간
  lastUserId    String?                             // 마지막 사용자
  currentApp    String?                             // 현재 실행 중인 프로그램
  currentAppIcon String?                            // 현재 프로그램 아이콘 URL
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sessions Session[]

  @@map("machines")
}

enum MachineStatus {
  OFF         // 꺼짐
  BOOTING     // 부팅 중 (WOL 전송됨)
  READY       // 켜짐, 사용 가능
  IN_USE      // 사용 중
  MAINTENANCE // 점검 중
}

model Queue {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  position  Int                              // 대기 순번
  status    QueueStatus @default(WAITING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("queue")
}

enum QueueStatus {
  WAITING     // 대기 중
  ASSIGNED    // PC 배정됨
  CANCELLED   // 취소
  EXPIRED     // 만료
}

model Session {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  machineId        String
  machine          Machine       @relation(fields: [machineId], references: [id])
  startedAt        DateTime      @default(now())
  endedAt          DateTime?
  creditsUsed      Int?                            // 세션에서 소모된 크레딧(분)
  scheduledEndAt   DateTime?                       // 예약 종료 시각
  status           SessionStatus @default(ACTIVE)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@map("sessions")
}

enum SessionStatus {
  ACTIVE
  ENDED
  INTERRUPTED  // 비정상 종료
}
